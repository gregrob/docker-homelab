# Ignore password files
**/secrets/*.pwd
**/secrets/*.secret
**/secrets/*.vault

# Ignore temp folder
temp/

# bambuddy host specific
docker/bambuddy/data/host/data/*
docker/bambuddy/data/host/logs/*
!docker/bambuddy/data/host/data/.gitkeep
!docker/bambuddy/data/host/logs/.gitkeep

# bambuddy host specific
docker/bambustudio/data/host/config/*
!docker/bambustudio/data/host/config/.gitkeep

# docker-volume-backup host specific
docker/docker-volume-backup/data/host/backups/*
!docker/docker-volume-backup/data/host/backups/.gitkeep

# frigate host specific
docker/frigate/data/host/db/*
docker/frigate/data/host/config/*
!docker/frigate/data/host/db/.gitkeep
!docker/frigate/data/host/config/.gitkeep

